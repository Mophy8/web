<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>記憶柑仔店 - 介面測試</title>
    <style>
        /* 基礎設定：防誤觸與大字體 */
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #fcf8f2;
            margin: 0;
            padding: 20px;
            user-select: none; /* 防止長輩按住文字跳出選取提示 */
            -webkit-user-select: none;
        }

        /* 頂部大字體提示區 */
        .header-box {
            text-align: center;
            background-color: #ffe8cc;
            border: 4px solid #d9480f;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 30px;
        }

        .title-text {
            font-size: 36px;
            font-weight: bold;
            color: #d9480f;
            margin: 0 0 10px 0;
        }

        .instruction-text {
            font-size: 42px;
            font-weight: bold;
            color: #2b2b2b;
            margin: 0;
        }

        /* 貨架網格：確保按鈕夠大、間距夠寬，防止誤觸 */
        .shelf-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }

        /* 大按鈕設計：高對比、點擊範圍大 */
        .item-btn {
            background-color: #ffffff;
            border: 5px solid #2b2b2b;
            border-radius: 24px;
            padding: 20px;
            cursor: pointer;
            box-shadow: 0 8px 0 #2b2b2b;
            transition: transform 0.1s, box-shadow 0.1s;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* 模擬點擊效果 */
        .item-btn:active {
            transform: translateY(4px);
            box-shadow: 0 4px 0 #2b2b2b;
        }

        /* 預留給商品的圖片空間 */
        .item-image-placeholder {
            width: 150px;
            height: 150px;
            background-color: #e9ecef;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #868e96;
            margin-bottom: 15px;
        }

        .item-label {
            font-size: 32px;
            font-weight: bold;
            color: #2b2b2b;
        }
    </style>
</head>
<body>

    <div class="header-box">
        <p class="title-text">第一關：客人的訂單</p>
        <p class="instruction-text">請點選【彈珠汽水】</p>
    </div>

    <div class="shelf-grid">
        <button class="item-btn" onclick="alert('答對了！')">
            <div class="item-image-placeholder">🧃</div>
            <span class="item-label">彈珠汽水</span>
        </button>

        <button class="item-btn" onclick="alert('再試一次喔！')">
            <div class="item-image-placeholder">🍬</div>
            <span class="item-label">柑仔糖</span>
        </button>
    </div>

</body>
</html>
